# file:./storage/db.sqlite
# mongodb://localhost:27017/nova
# supabase://project-ref.supabase.co?key=service-role-key

NOVA_CACHE_DRIVER=memory
# NOVA_REDIS_URL=redis://localhost:6379

NOVA_STORAGE_DRIVER=local
