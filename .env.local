NOVA_APP_NAME=Nova
NOVA_APP_URL=http://localhost:3000
NOVA_ENV=development
NOVA_HOST=0.0.0.0
NOVA_PORT=3000
NOVA_KERNEL_ADAPTER=node
NOVA_LOG_LEVEL=debug

NOVA_DB_CONNECTION=postgres
NOVA_DATABASE_URL=postgres://nova:nova@localhost:5432/nova
